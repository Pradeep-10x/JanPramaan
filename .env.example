# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/janpramaan_dev

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ─── Server ────────────────────────────────────────────────
PORT=4000
UPLOAD_DIR=./uploads

# ─── Privacy ───────────────────────────────────────────────
